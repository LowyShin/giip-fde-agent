# ── Slack ────────────────────────────────────────────────────────────────────
# Bot Token (xoxb-...)  Settings > OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-Level Token (xapp-...)  Settings > Basic Information > App-Level Tokens
# Required scope: connections:write
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Comma-separated channel IDs the bot listens to (optional — DMs always work)
# SLACK_CHANNEL_IDS=C0123456789,C9876543210

# ── Bot identity ──────────────────────────────────────────────────────────────
# Display name used in Slack messages
BOT_NAME=giipclaude Bot

# ── Workspace / project directories ──────────────────────────────────────────
# Root directory of the workspace (where .agent/ lives and git push targets)
WORKSPACE_DIR=/path/to/your/workspace

# Parent directory of all sub-projects (for multi-project prefix switching)
# Default: parent of WORKSPACE_DIR
# PROJECTS_ROOT=/path/to/projects

# ── Claude CLI ────────────────────────────────────────────────────────────────
# Model to use for analysis and Q&A (sync calls)
# Defaults to claude-opus-4-8
# CLAUDE_MODEL=claude-opus-4-8

# ── GitHub Integration (optional) ────────────────────────────────────────────
# GitHub personal access token (repo scope)
# GITHUB_TOKEN=ghp_your_token_here

# GitHub repository for issue tracking (owner/repo format)
# GITHUB_REPO=your-org/your-repo

# ── Repo push monitoring (optional) ──────────────────────────────────────────
# Comma-separated list of repos to check for unpushed commits
# Format: name:relative-path:branch
# Example: REPOS_TO_CHECK=frontend:apps/web:main,backend:services/api:main
# If not set, auto-detects git repos inside WORKSPACE_DIR
# REPOS_TO_CHECK=
