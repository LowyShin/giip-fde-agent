# Jikji generated artifacts — do not commit unless explicitly desired
.jikji/
.jikji_agent_map.md

# Python cache/artifacts
__pycache__/
*.py[cod]

# Block accidental project-specific cache roots (e.g. PYTHONPYCACHEPREFIX=giipdb)
giipdb/

# slack-bot runtime state (machine-local, must NOT be versioned) — dirty tree breaks rebase/push
slack-bot/.bot-threads.json
slack-bot/.task-state.json
slack-bot/tasklist.json

# slack-bot giip 계정 시크릿(SK) — 실값 비커밋, *.sample 만 추적
slack-bot/.secrets/*
!slack-bot/.secrets/*.sample.json
